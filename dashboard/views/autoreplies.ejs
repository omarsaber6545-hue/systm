<%- include('partials/header') %>

<%- include('partials/sidebar', { activeTab: 'autoreplies' }) %>

<main class="app-content">
    <div class="content-header">
        <h1><i class="fa-solid fa-reply-all"></i> الردود التلقائية</h1>
        <p>اجعل البوت يرد تلقائياً على عبارات أو كلمات معينة</p>
    </div>

    <div class="glass-panel">
        <% if (typeof req !== 'undefined' && req.query && req.query.success) { %>
            <div class="alert alert-success"><i class="fa-solid fa-check-circle"></i> <%= req.query.success %></div>
        <% } %>

        <% if (replies && replies.length > 0) { %>
            <div style="display: flex; flex-direction: column; gap: 12px; margin-bottom: 30px;">
                <% replies.forEach(reply => { %>
                    <div style="background: rgba(0,0,0,0.3); border: 1px solid var(--glass-border); padding: 18px 22px; border-radius: 12px; display: flex; justify-content: space-between; align-items: center;">
                        <div>
                            <div style="margin-bottom: 6px;">
                                <span style="color: var(--text-muted); font-size: 0.8rem; font-weight: 600;">المحفّز</span>
                                <span style="margin-right: 8px; font-weight: 700; color: var(--primary);"><%= reply.trigger %></span>
                            </div>
                            <div>
                                <span style="color: var(--text-muted); font-size: 0.8rem; font-weight: 600;">الرد</span>
                                <span style="margin-right: 8px; color: #d0d0d0;"><%= reply.response %></span>
                            </div>
                        </div>
                        <form action="/dashboard/<%= guild.id %>/autoreplies/delete" method="POST" style="margin:0;">
                            <input type="hidden" name="trigger" value="<%= reply.trigger %>">
                            <button type="submit" class="btn btn-danger" title="حذف"><i class="fa-solid fa-trash"></i></button>
                        </form>
                    </div>
                <% }) %>
            </div>
        <% } else { %>
            <div style="text-align: center; padding: 40px; color: var(--text-muted); margin-bottom: 20px;">
                <i class="fa-solid fa-inbox" style="font-size: 2.5rem; margin-bottom: 15px; display: block; opacity: 0.4;"></i>
                لا توجد ردود تلقائية مضافة حتى الآن
            </div>
        <% } %>

        <hr style="border-color: var(--glass-border); margin: 25px 0;">

        <h3 style="margin-bottom: 20px; color: var(--primary);">إضافة رد تلقائي جديد</h3>
        <form action="/dashboard/<%= guild.id %>/autoreplies" method="POST" class="settings-form">
            <div class="form-group">
                <label for="trigger">عبارة المحفّز</label>
                <input type="text" id="trigger" name="trigger" class="glass-input" required placeholder="مثال السلام عليكم">
            </div>

            <div class="form-group">
                <label for="response">رد البوت</label>
                <input type="text" id="response" name="response" class="glass-input" required placeholder="مثال وعليكم السلام ورحمة الله">
            </div>

            <button type="submit" class="btn btn-primary"><i class="fa-solid fa-plus"></i> إضافة الرد</button>
        </form>
    </div>
</main>

<%- include('partials/footer') %>
