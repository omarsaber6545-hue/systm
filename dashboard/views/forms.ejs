<%- include('partials/header') %>

<%- include('partials/sidebar', { guild, activeTab: 'forms' }) %>

<main class="app-content">
    <div class="content-header">
        <h1><i class="fa-solid fa-clipboard-question"></i> نظام التقديمات</h1>
        <p>أنشئ استمارات تقديم مخصصة ليتقدم الأعضاء من خلالها</p>
    </div>

    <% if (typeof success !== 'undefined') { %>
        <div class="alert alert-success"><i class="fa-solid fa-check-circle"></i> <%= success %></div>
    <% } %>
    <% if (typeof error !== 'undefined') { %>
        <div class="alert alert-success" style="background: rgba(237, 66, 69, 0.1); border-color: rgba(237,66,69,0.3); color: #ED4245;"><i class="fa-solid fa-triangle-exclamation"></i> <%= error %></div>
    <% } %>

    <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 30px;">
        <!-- نموذج الإنشاء -->
        <div class="glass-panel">
            <form action="/dashboard/<%= guild.id %>/forms" method="POST" id="formsForm">
                <h3 style="margin-bottom: 20px; color: var(--primary);">١ تصميم الإمبيد</h3>
                <div class="form-group">
                    <label>عنوان الإمبيد</label>
                    <input type="text" name="title" id="title" class="glass-input" value="<%= settings.panel_data.title || 'التقديم للطاقم' %>" required>
                </div>
                <div class="form-group">
                    <label>وصف الإمبيد</label>
                    <textarea name="description" id="description" class="glass-input" rows="4" required><%= settings.panel_data.description || 'اضغط على الزر أدناه للتقديم.' %></textarea>
                </div>
                <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 15px;">
                    <div class="form-group">
                        <label>لون الإمبيد</label>
                        <input type="color" name="color" id="color" class="glass-input" style="height: 50px; padding: 5px;" value="<%= settings.panel_data.color || '#5865F2' %>">
                    </div>
                    <div class="form-group">
                        <label>رابط الصورة المصغرة (اختياري)</label>
                        <input type="url" name="thumbnail" id="thumbnail" class="glass-input" placeholder="https://..." value="<%= settings.panel_data.thumbnail || '' %>">
                    </div>
                </div>
                <div class="form-group">
                    <label>رابط الصورة الكبيرة (اختياري)</label>
                    <input type="url" name="image" id="image" class="glass-input" placeholder="https://..." value="<%= settings.panel_data.image || '' %>">
                </div>

                <hr style="border-color: rgba(255,255,255,0.1); margin: 30px 0;">

                <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 15px;">
                    <div>
                        <h3 style="color: var(--primary);">٢ أسئلة الاستمارة</h3>
                        <small style="color: var(--text-muted);">الحد الأقصى 5 أسئلة بسبب قيود ديسكورد</small>
                    </div>
                    <button type="button" class="btn btn-secondary" onclick="addQuestionRow()"><i class="fa-solid fa-plus"></i> إضافة سؤال</button>
                </div>
                <div id="questionsContainer"></div>
                <input type="hidden" name="questions" id="questions_data">

                <hr style="border-color: rgba(255,255,255,0.1); margin: 30px 0;">

                <h3 style="margin-bottom: 15px; color: var(--primary);">٣ القنوات والنشر</h3>
                <div class="form-group" style="margin-top:15px;">
                    <label>قناة استقبال التقديمات</label>
                    <select name="log_channel" class="glass-input" required>
                        <option value="">-- اختر القناة --</option>
                        <% textChannels.forEach(c => { %>
                            <option value="<%= c.id %>" <%= settings.log_channel === c.id ? 'selected' : '' %>># <%= c.name %></option>
                        <% }) %>
                    </select>
                </div>
                <div class="form-group" style="margin-top:15px;">
                    <label>قناة نشر لوحة التقديم</label>
                    <select name="panel_channel" class="glass-input">
                        <option value="">-- اختر القناة --</option>
                        <% textChannels.forEach(c => { %>
                            <option value="<%= c.id %>"># <%= c.name %></option>
                        <% }) %>
                    </select>
                </div>
                <div class="form-group">
                    <label>
                        <input type="checkbox" name="send_panel" value="yes">
                        إرسال / تحديث اللوحة الآن
                    </label>
                    <small>فعّل هذا لإرسال لوحة التقديم إلى القناة المختارة</small>
                </div>

                <button type="submit" class="btn btn-primary" style="width: 100%;" onclick="prepareSubmit(event)">
                    <i class="fa-solid fa-save"></i> حفظ ونشر
                </button>
            </form>
        </div>

        <!-- المعاينة المباشرة -->
        <div>
            <div class="glass-panel" style="position: sticky; top: 90px;">
                <h3 style="margin-bottom: 20px;"><i class="fa-brands fa-discord"></i> معاينة مباشرة</h3>
                <div style="background: #36393f; border-radius: 8px; padding: 16px; font-family: 'gg sans', Arial, sans-serif;">
                    <div style="display: flex; gap: 16px;">
                        <img src="<%= client.user.displayAvatarURL() %>" style="width: 40px; height: 40px; border-radius: 50%;">
                        <div style="flex: 1;">
                            <div style="display: flex; align-items: center; gap: 8px; margin-bottom: 8px;">
                                <span style="color: #fff; font-weight: 500;"><%= client.user.username %></span>
                                <span style="background: #5865F2; color: #fff; font-size: 0.65rem; padding: 1px 4px; border-radius: 3px; font-weight: 600;">BOT</span>
                            </div>
                            <div id="preview-embed" style="border-left: 4px solid #5865F2; background: #2f3136; padding: 16px; border-radius: 4px; display: flex; gap: 16px;">
                                <div style="flex: 1;">
                                    <div id="preview-title" style="color: #fff; font-weight: 600; font-size: 1rem; margin-bottom: 8px;"></div>
                                    <div id="preview-desc" style="color: #dcddde; font-size: 0.875rem; white-space: pre-wrap; line-height: 1.375;"></div>
                                    <img id="preview-image" src="" style="max-width: 100%; max-height: 300px; border-radius: 4px; margin-top: 16px; display: none;">
                                </div>
                                <img id="preview-thumb" src="" style="width: 80px; height: 80px; border-radius: 4px; object-fit: contain; display: none;">
                            </div>
                            <div id="preview-components" style="margin-top: 8px; display: flex; flex-wrap: wrap; gap: 8px;">
                                <div style="background: #5865F2; color: #fff; padding: 8px 16px; border-radius: 3px; font-weight: 500; font-size: 0.875rem; display: flex; align-items: center; gap: 8px; cursor: default;">
                                    <span>📝</span> <span>قدّم الآن</span>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</main>

<script>
    const existingQuestions = <%- settings.questions || '[]' %>;
</script>

<script>
    const questionsContainer = document.getElementById('questionsContainer');
    let questionCount = 0;

    function addQuestionRow(questionText = '') {
        if (questionCount >= 5) {
            alert('الحد الأقصى هو 5 أسئلة فقط بسبب قيود ديسكورد.');
            return;
        }
        const div = document.createElement('div');
        div.className = "question-row";
        div.style.cssText = "background: rgba(0,0,0,0.2); padding: 15px; border-radius: 8px; margin-bottom: 15px; border: 1px solid rgba(255,255,255,0.1); position: relative;";
        div.innerHTML = `
            <button type="button" onclick="this.parentElement.remove(); questionCount--;" style="position: absolute; top: 10px; left: 10px; background: transparent; border: none; color: var(--danger); cursor: pointer;"><i class="fa-solid fa-trash"></i></button>
            <div class="form-group" style="margin-bottom: 0;">
                <label style="font-size: 0.85rem;">السؤال</label>
                <input type="text" class="glass-input question-input" placeholder="مثال: كم عمرك؟" value="${questionText}" required>
            </div>
        `;
        questionsContainer.appendChild(div);
        questionCount++;
    }

    if (existingQuestions.length > 0) {
        existingQuestions.forEach(q => addQuestionRow(q));
    } else {
        addQuestionRow();
    }

    function prepareSubmit(e) {
        const inputs = document.querySelectorAll('.question-input');
        const questionsData = [];
        inputs.forEach(input => {
            const val = input.value.trim();
            if (val) questionsData.push(val);
        });
        if (questionsData.length === 0) {
            e.preventDefault();
            alert('يجب إضافة سؤال واحد على الأقل');
            return;
        }
        document.getElementById('questions_data').value = JSON.stringify(questionsData);
    }

    const formInputs = ['title', 'description', 'color', 'thumbnail', 'image'];
    formInputs.forEach(id => document.getElementById(id).addEventListener('input', updatePreview));

    function updatePreview() {
        const title = document.getElementById('title').value;
        const desc = document.getElementById('description').value;
        const color = document.getElementById('color').value;
        const thumb = document.getElementById('thumbnail').value;
        const img = document.getElementById('image').value;

        document.getElementById('preview-embed').style.borderLeftColor = color;
        document.getElementById('preview-title').innerText = title;
        document.getElementById('preview-desc').innerText = desc;

        const pThumb = document.getElementById('preview-thumb');
        if (thumb) { pThumb.src = thumb; pThumb.style.display = 'block'; } else { pThumb.style.display = 'none'; }

        const pImg = document.getElementById('preview-image');
        if (img) { pImg.src = img; pImg.style.display = 'block'; } else { pImg.style.display = 'none'; }
    }

    updatePreview();
</script>

<%- include('partials/footer') %>
