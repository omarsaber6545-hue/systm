<%- include('partials/header') %>

<%- include('partials/sidebar', { activeTab: 'tempvoice' }) %>

<main class="app-content">
    <div class="content-header">
        <h1><i class="fa-solid fa-microphone-lines"></i> الرومات المؤقتة</h1>
        <p>قم بإعداد نظام الرومات الصوتية المؤقتة في سيرفرك</p>
    </div>

    <div class="glass-panel">
        <% if (typeof req !== 'undefined' && req.query && req.query.success) { %>
            <div class="alert alert-success"><i class="fa-solid fa-check-circle"></i> <%= req.query.success %></div>
        <% } %>

        <form action="/dashboard/<%= guild.id %>/tempvoice" method="POST" class="settings-form">
            <div class="form-group">
                <label for="master_channel">الروم الأساسي (Master Channel)</label>
                <select id="master_channel" name="master_channel" class="glass-input">
                    <option value="">-- اختر روم صوتي --</option>
                    <% channels.forEach(channel => { %>
                        <option value="<%= channel.id %>" <%= settings.master_channel === channel.id ? 'selected' : '' %>>
                            🔊 <%= channel.name %>
                        </option>
                    <% }) %>
                </select>
                <small>الروم الذي سيدخله الأعضاء لإنشاء روماتهم المؤقتة</small>
            </div>

            <div class="form-group">
                <label for="category_id">الكاتيجوري (Category)</label>
                <select id="category_id" name="category_id" class="glass-input">
                    <option value="">-- اختر كاتيجوري --</option>
                    <% categories.forEach(cat => { %>
                        <option value="<%= cat.id %>" <%= settings.category_id === cat.id ? 'selected' : '' %>>
                            📁 <%= cat.name %>
                        </option>
                    <% }) %>
                </select>
                <small>القسم الذي سيتم إنشاء الرومات المؤقتة بداخله</small>
            </div>

            <button type="submit" class="btn btn-primary"><i class="fa-solid fa-save"></i> حفظ التغييرات</button>
        </form>
    </div>
</main>

<%- include('partials/footer') %>
