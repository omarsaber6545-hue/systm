<%- include('partials/header') %>

<style>
.discord-preview-container {
    background-color: #313338;
    border-radius: 8px;
    padding: 16px;
    font-family: 'gg sans', 'Inter', sans-serif;
    color: #dbdee1;
    margin-top: 20px;
    display: flex;
}
.discord-embed {
    background-color: #2b2d31;
    border-radius: 4px;
    border-left: 4px solid #5865F2;
    padding: 16px;
    display: flex;
    flex-direction: column;
    max-width: 520px;
    width: 100%;
}
.embed-author {
    display: flex;
    align-items: center;
    margin-bottom: 8px;
    font-size: 14px;
    font-weight: 600;
    color: #ffffff;
}
.embed-author img {
    width: 24px; height: 24px; border-radius: 50%;
    margin-left: 8px; display: none;
}
.embed-title { font-size: 16px; font-weight: 600; color: #00A8FC; margin-bottom: 8px; display: none; }
.embed-description { font-size: 14px; line-height: 1.375; white-space: pre-wrap; display: none; }
.embed-thumbnail { max-width: 80px; max-height: 80px; border-radius: 4px; margin-right: 16px; display: none; }
.embed-image { max-width: 100%; border-radius: 4px; margin-top: 16px; display: none; }
.embed-footer { display: flex; align-items: center; margin-top: 8px; font-size: 12px; color: #949ba4; }
.embed-footer img { width: 20px; height: 20px; border-radius: 50%; margin-left: 8px; display: none; }
.embed-footer span { display: none; }
.embed-content-wrapper { display: flex; justify-content: space-between; }
</style>

<%- include('partials/sidebar', { activeTab: 'embed' }) %>

<main class="app-content">
    <div class="content-header">
        <h1><i class="fa-solid fa-paintbrush"></i> صانع الإمبيد المتقدم</h1>
        <p>صمّم إمبيداً مخصصاً مع معاينة مباشرة وتحكم كامل في التصميم</p>
    </div>

    <div class="glass-panel">
        <% if (typeof req !== 'undefined' && req.query && req.query.success) { %>
            <div class="alert alert-success"><i class="fa-solid fa-check-circle"></i> <%= req.query.success %></div>
        <% } %>
        <% if (typeof req !== 'undefined' && req.query && req.query.error) { %>
            <div class="alert alert-success" style="background: rgba(237, 66, 69, 0.1); border-color: rgba(237,66,69,0.3); color: #ED4245;"><i class="fa-solid fa-triangle-exclamation"></i> <%= req.query.error %></div>
        <% } %>

        <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 30px; margin-top: 20px;">
            <!-- قسم النموذج -->
            <div>
                <form action="/dashboard/<%= guild.id %>/embed" method="POST" class="settings-form">

                    <div class="form-group">
                        <label for="channel">قناة الإرسال (مطلوب)</label>
                        <select id="channel" name="channel" class="glass-input" required>
                            <option value="">-- اختر القناة --</option>
                            <% channels.forEach(c => { %>
                                <option value="<%= c.id %>"><%= c.name %></option>
                            <% }) %>
                        </select>
                    </div>

                    <hr style="border-color: rgba(255,255,255,0.1); margin: 20px 0;">

                    <div class="guild-grid" style="grid-template-columns: 1fr 1fr; gap: 15px;">
                        <div class="form-group">
                            <label for="author_name">اسم المؤلف</label>
                            <input type="text" id="author_name" name="author_name" class="glass-input" placeholder="مثال النظام">
                        </div>
                        <div class="form-group">
                            <label for="author_icon">رابط أيقونة المؤلف</label>
                            <input type="url" id="author_icon" name="author_icon" class="glass-input" placeholder="https://...">
                        </div>
                    </div>

                    <div class="guild-grid" style="grid-template-columns: 2fr 1fr; gap: 15px; margin-top: 15px;">
                        <div class="form-group">
                            <label for="title">عنوان الإمبيد</label>
                            <input type="text" id="title" name="title" class="glass-input" placeholder="النص الرئيسي للعنوان">
                        </div>
                        <div class="form-group">
                            <label for="color">اللون</label>
                            <input type="color" id="color" name="color" class="glass-input" value="#5865F2" style="height: 48px; padding: 0 10px; cursor: pointer;">
                        </div>
                    </div>

                    <div class="form-group" style="margin-top: 15px;">
                        <label for="description">وصف الإمبيد</label>
                        <textarea id="description" name="description" class="glass-input" rows="5" placeholder="محتوى النص الرئيسي (يدعم Markdown)"></textarea>
                    </div>

                    <div class="guild-grid" style="grid-template-columns: 1fr 1fr; gap: 15px; margin-top: 15px;">
                        <div class="form-group">
                            <label for="thumbnail">رابط الصورة المصغرة (أعلى اليمين)</label>
                            <input type="url" id="thumbnail" name="thumbnail" class="glass-input" placeholder="https://...">
                        </div>
                        <div class="form-group">
                            <label for="image">رابط الصورة الكبيرة (الأسفل)</label>
                            <input type="url" id="image" name="image" class="glass-input" placeholder="https://...">
                        </div>
                    </div>

                    <div class="guild-grid" style="grid-template-columns: 1fr 1fr; gap: 15px; margin-top: 15px;">
                        <div class="form-group">
                            <label for="footer_text">نص الفوتر</label>
                            <input type="text" id="footer_text" name="footer_text" class="glass-input" placeholder="مثال مشغّل بواسطة E-246">
                        </div>
                        <div class="form-group">
                            <label for="footer_icon">رابط أيقونة الفوتر</label>
                            <input type="url" id="footer_icon" name="footer_icon" class="glass-input" placeholder="https://...">
                        </div>
                    </div>

                    <div class="form-group" style="margin-top: 15px;">
                        <label>
                            <input type="checkbox" id="timestamp" name="timestamp" value="true"> إضافة التوقيت (التاريخ والوقت الحالي)
                        </label>
                    </div>

                    <button type="submit" class="btn btn-primary" style="margin-top: 25px; width: 100%;">
                        <i class="fa-solid fa-paper-plane"></i> إرسال الإمبيد
                    </button>
                </form>
            </div>

            <!-- قسم المعاينة -->
            <div>
                <h3 style="margin-bottom: 15px; color: var(--primary);">معاينة مباشرة</h3>
                <div class="discord-preview-container">
                    <div class="discord-embed" id="preview_embed">
                        <div class="embed-author" id="preview_author_container">
                            <img id="preview_author_icon" src="" alt="">
                            <span id="preview_author_name"></span>
                        </div>

                        <div class="embed-content-wrapper">
                            <div style="flex-grow: 1;">
                                <div class="embed-title" id="preview_title"></div>
                                <div class="embed-description" id="preview_description"></div>
                            </div>
                            <img class="embed-thumbnail" id="preview_thumbnail" src="" alt="">
                        </div>

                        <img class="embed-image" id="preview_image" src="" alt="">

                        <div class="embed-footer" id="preview_footer_container">
                            <img id="preview_footer_icon" src="" alt="">
                            <span id="preview_footer_text"></span>
                            <span id="preview_timestamp" style="margin-right: 5px; color: #949ba4; display: none;"></span>
                        </div>
                    </div>
                </div>
            </div>

        </div>
    </div>
</main>

<script>
    function updatePreview() {
        const color = document.getElementById('color').value;
        const authorName = document.getElementById('author_name').value;
        const authorIcon = document.getElementById('author_icon').value;
        const title = document.getElementById('title').value;
        const description = document.getElementById('description').value;
        const thumbnail = document.getElementById('thumbnail').value;
        const image = document.getElementById('image').value;
        const footerText = document.getElementById('footer_text').value;
        const footerIcon = document.getElementById('footer_icon').value;
        const timestamp = document.getElementById('timestamp').checked;

        document.getElementById('preview_embed').style.borderLeftColor = color;

        const authorNameEl = document.getElementById('preview_author_name');
        const authorIconEl = document.getElementById('preview_author_icon');
        if (authorName) {
            authorNameEl.textContent = authorName;
            authorNameEl.style.display = 'inline';
            if (authorIcon) { authorIconEl.src = authorIcon; authorIconEl.style.display = 'inline'; }
            else { authorIconEl.style.display = 'none'; }
        } else {
            authorNameEl.style.display = 'none';
            authorIconEl.style.display = 'none';
        }

        const titleEl = document.getElementById('preview_title');
        if (title) { titleEl.textContent = title; titleEl.style.display = 'block'; }
        else { titleEl.style.display = 'none'; }

        const descEl = document.getElementById('preview_description');
        if (description) { descEl.textContent = description; descEl.style.display = 'block'; }
        else { descEl.style.display = 'none'; }

        const thumbEl = document.getElementById('preview_thumbnail');
        if (thumbnail) { thumbEl.src = thumbnail; thumbEl.style.display = 'block'; }
        else { thumbEl.style.display = 'none'; }

        const imgEl = document.getElementById('preview_image');
        if (image) { imgEl.src = image; imgEl.style.display = 'block'; }
        else { imgEl.style.display = 'none'; }

        const fTextEl = document.getElementById('preview_footer_text');
        const fIconEl = document.getElementById('preview_footer_icon');
        const tsEl = document.getElementById('preview_timestamp');
        let hasFooter = false;

        if (footerText) {
            fTextEl.textContent = footerText;
            fTextEl.style.display = 'inline';
            hasFooter = true;
            if (footerIcon) { fIconEl.src = footerIcon; fIconEl.style.display = 'inline'; }
            else { fIconEl.style.display = 'none'; }
        } else {
            fTextEl.style.display = 'none';
            fIconEl.style.display = 'none';
        }

        if (timestamp) {
            const now = new Date();
            const timeStr = now.toLocaleTimeString('ar', { hour: '2-digit', minute: '2-digit' });
            tsEl.textContent = hasFooter ? ' • اليوم الساعة ' + timeStr : 'اليوم الساعة ' + timeStr;
            tsEl.style.display = 'inline';
        } else {
            tsEl.style.display = 'none';
        }
    }

    const inputs = ['color', 'author_name', 'author_icon', 'title', 'description', 'thumbnail', 'image', 'footer_text', 'footer_icon'];
    inputs.forEach(id => document.getElementById(id).addEventListener('input', updatePreview));
    document.getElementById('timestamp').addEventListener('change', updatePreview);
    updatePreview();
</script>

<%- include('partials/footer') %>
