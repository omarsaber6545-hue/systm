<%- include('partials/header') %>
<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

<style>
.stats-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
    gap: 20px;
    margin-bottom: 30px;
}
.chart-card {
    background: rgba(30, 31, 34, 0.6);
    backdrop-filter: blur(15px);
    border: 1px solid rgba(255, 255, 255, 0.05);
    border-radius: 12px;
    padding: 20px;
    box-shadow: 0 8px 32px rgba(0,0,0,0.15);
    display: flex;
    flex-direction: column;
}
.chart-card h3 {
    margin-top: 0;
    margin-bottom: 15px;
    font-size: 1.1rem;
    color: #fff;
    display: flex;
    align-items: center;
    gap: 8px;
}
.chart-container {
    position: relative;
    height: 250px;
    width: 100%;
}
</style>

<!-- Sidebar -->
<%- include('partials/sidebar', { activeTab: 'general' }) %>

<!-- Content Area -->
<main class="app-content">
    <div class="content-header" style="margin-bottom: 25px;">
        <h1><i class="fa-solid fa-server"></i> <%= guild.name %></h1>
        <p>مراقبة نشاط السيرفر وإحصائياته وتغيير الإعدادات العامة للبوت</p>
    </div>

    <!-- Stats Grid -->
    <div class="stats-grid">
        <!-- Members growth chart -->
        <div class="chart-card">
            <h3><i class="fa-solid fa-users"></i> حركة الأعضاء (آخر 7 أيام)</h3>
            <div class="chart-container">
                <canvas id="membersChart"></canvas>
            </div>
        </div>

        <!-- Voice duration chart -->
        <div class="chart-card">
            <h3><i class="fa-solid fa-microphone"></i> دقائق التفاعل الصوتي (آخر 7 أيام)</h3>
            <div class="chart-container">
                <canvas id="voiceChart"></canvas>
            </div>
        </div>

        <!-- Hourly message chart -->
        <div class="chart-card" style="grid-column: span 1;">
            <h3><i class="fa-solid fa-message"></i> نشاط الكتابة بالساعات</h3>
            <div class="chart-container">
                <canvas id="messagesChart"></canvas>
            </div>
        </div>
    </div>

    <div class="glass-panel">
        <h2>الإعدادات العامة</h2>
        <p>تكوين الإعدادات الأساسية لسيرفرك</p>

        <% if (typeof req !== 'undefined' && req.query && req.query.success) { %>
            <div class="alert alert-success">
                <%= req.query.success %>
            </div>
        <% } %>

        <form action="/dashboard/<%= guild.id %>/general" method="POST" class="settings-form">

            <div class="form-group">
                <label for="log_channel">أيدي روم سجلات الإشراف (Mod Log)</label>
                <input type="text" id="log_channel" name="log_channel" class="glass-input" value="<%= (settings && settings.log_channel) ? settings.log_channel : 'none' %>">
                <small>اكتب 'none' لتعطيل سجلات الإشراف</small>
            </div>

            <div class="form-group" style="margin-top: 15px;">
                <label for="reply_type">نوع ردود البوت (Bot Reply Type)</label>
                <select id="reply_type" name="reply_type" class="glass-input">
                    <option value="embed" <%= (settings && settings.reply_type === 'embed') ? 'selected' : '' %>>بطاقة (Embed Message)</option>
                    <option value="normal" <%= (settings && settings.reply_type === 'normal') ? 'selected' : '' %>>رسالة عادية (Normal Message)</option>
                </select>
                <small>اختر ما إذا كان البوت يرسل الردود كرسائل عادية أو بطاقات مدمجة</small>
            </div>

            <button type="submit" class="btn btn-primary" style="margin-top: 15px;">حفظ التغييرات</button>
        </form>
    </div>
</main>

<script>
    // Process Member Stats
    const rawMemberStats = <%- JSON.stringify(memberStats) %>;
    const memberLabels = [];
    const joinsData = [];
    const leavesData = [];

    // Fill last 7 days default if empty
    if (rawMemberStats.length === 0) {
        for (let i = 6; i >= 0; i--) {
            const d = new Date();
            d.setDate(d.getDate() - i);
            const dateStr = d.toISOString().split('T')[0];
            memberLabels.push(dateStr);
            joinsData.push(0);
            leavesData.push(0);
        }
    } else {
        rawMemberStats.forEach(stat => {
            memberLabels.push(stat.date);
            joinsData.push(stat.joins);
            leavesData.push(stat.leaves);
        });
    }

    // Process Voice Stats
    const rawVoiceStats = <%- JSON.stringify(voiceStats) %>;
    const voiceLabels = [];
    const voiceData = []; // in minutes

    if (rawVoiceStats.length === 0) {
        for (let i = 6; i >= 0; i--) {
            const d = new Date();
            d.setDate(d.getDate() - i);
            const dateStr = d.toISOString().split('T')[0];
            voiceLabels.push(dateStr);
            voiceData.push(0);
        }
    } else {
        rawVoiceStats.forEach(stat => {
            voiceLabels.push(stat.date);
            voiceData.push(Math.round(stat.seconds / 60)); // convert seconds to minutes
        });
    }

    // Process Messages Stats (24 Hours)
    const rawMessageStats = <%- JSON.stringify(messageStats) %>;
    const messageLabels = Array.from({length: 24}, (_, i) => `${i}:00`);
    const messageData = Array(24).fill(0);

    rawMessageStats.forEach(stat => {
        if (stat.hour >= 0 && stat.hour < 24) {
            messageData[stat.hour] = stat.count;
        }
    });

    // Render Members Chart
    new Chart(document.getElementById('membersChart'), {
        type: 'line',
        data: {
            labels: memberLabels,
            datasets: [
                {
                    label: 'انضمام',
                    data: joinsData,
                    borderColor: '#23a559',
                    backgroundColor: 'rgba(35, 165, 89, 0.1)',
                    tension: 0.3,
                    fill: true
                },
                {
                    label: 'مغادرة',
                    data: leavesData,
                    borderColor: '#f23f43',
                    backgroundColor: 'rgba(242, 63, 67, 0.1)',
                    tension: 0.3,
                    fill: true
                }
            ]
        },
        options: {
            responsive: true,
            maintainAspectRatio: false,
            plugins: {
                legend: { labels: { color: '#B5BAC1', font: { family: 'IBM Plex Sans Arabic' } } }
            },
            scales: {
                x: { grid: { color: 'rgba(255,255,255,0.05)' }, ticks: { color: '#B5BAC1' } },
                y: { grid: { color: 'rgba(255,255,255,0.05)' }, ticks: { color: '#B5BAC1', stepSize: 1 } }
            }
        }
    });

    // Render Voice Chart
    new Chart(document.getElementById('voiceChart'), {
        type: 'line',
        data: {
            labels: voiceLabels,
            datasets: [{
                label: 'دقائق الصوت',
                data: voiceData,
                borderColor: '#8C52FF',
                backgroundColor: 'rgba(140, 82, 255, 0.15)',
                tension: 0.3,
                fill: true
            }]
        },
        options: {
            responsive: true,
            maintainAspectRatio: false,
            plugins: {
                legend: { display: false }
            },
            scales: {
                x: { grid: { color: 'rgba(255,255,255,0.05)' }, ticks: { color: '#B5BAC1' } },
                y: { grid: { color: 'rgba(255,255,255,0.05)' }, ticks: { color: '#B5BAC1', stepSize: 1 } }
            }
        }
    });

    // Render Messages Chart
    new Chart(document.getElementById('messagesChart'), {
        type: 'bar',
        data: {
            labels: messageLabels,
            datasets: [{
                label: 'الرسائل المرسلة',
                data: messageData,
                backgroundColor: '#5865F2',
                borderRadius: 4
            }]
        },
        options: {
            responsive: true,
            maintainAspectRatio: false,
            plugins: {
                legend: { display: false }
            },
            scales: {
                x: { grid: { display: false }, ticks: { color: '#B5BAC1', maxRotation: 45, minRotation: 45 } },
                y: { grid: { color: 'rgba(255,255,255,0.05)' }, ticks: { color: '#B5BAC1', stepSize: 1 } }
            }
        }
    });
</script>

<%- include('partials/footer') %>
