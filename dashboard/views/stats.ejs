<%- include('partials/header') %>

<%- include('partials/sidebar', { guild, activeTab: 'stats' }) %>

<main class="app-content">
    <div class="content-header">
        <h1><i class="fa-solid fa-chart-column"></i> الإحصائيات (Leaderboard)</h1>
        <p>استعرض أكثر الأعضاء تفاعلاً بالرسائل الصوت والريأكشن في سيرفرك</p>
    </div>

    <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(300px, 1fr)); gap: 20px; margin-top: 20px;">
        
        <!-- Messages Leaderboard -->
        <div class="glass-panel">
            <h3 style="color: var(--primary); margin-bottom: 15px;"><i class="fa-solid fa-message"></i> أكثر الأعضاء إرسالاً للرسائل</h3>
            <ul style="list-style: none; padding: 0;">
                <% if (topMessages && topMessages.length > 0) { %>
                    <% topMessages.forEach((user, index) => { %>
                        <li style="display: flex; align-items: center; justify-content: space-between; padding: 10px; background: rgba(255,255,255,0.05); margin-bottom: 8px; border-radius: 8px;">
                            <div style="display: flex; align-items: center; gap: 10px;">
                                <span style="font-weight: bold; color: var(--primary);"><%= index + 1 %>.</span>
                                <span><i class="fa-solid fa-user"></i> ID: <%= user.userId %></span>
                            </div>
                            <span style="font-weight: bold; color: #00BFFF;"><%= user.messages %> رسالة</span>
                        </li>
                    <% }) %>
                <% } else { %>
                    <li style="padding: 10px; text-align: center; color: rgba(255,255,255,0.5);">لا توجد إحصائيات بعد</li>
                <% } %>
            </ul>
        </div>

        <!-- Voice Leaderboard -->
        <div class="glass-panel">
            <h3 style="color: var(--primary); margin-bottom: 15px;"><i class="fa-solid fa-microphone"></i> أكثر الأعضاء تواجداً بالصوت</h3>
            <ul style="list-style: none; padding: 0;">
                <% if (topVoice && topVoice.length > 0) { %>
                    <% topVoice.forEach((user, index) => { 
                        const hours = Math.floor(user.voice_xp / 60);
                        const mins = user.voice_xp % 60;
                    %>
                        <li style="display: flex; align-items: center; justify-content: space-between; padding: 10px; background: rgba(255,255,255,0.05); margin-bottom: 8px; border-radius: 8px;">
                            <div style="display: flex; align-items: center; gap: 10px;">
                                <span style="font-weight: bold; color: var(--primary);"><%= index + 1 %>.</span>
                                <span><i class="fa-solid fa-user"></i> ID: <%= user.userId %></span>
                            </div>
                            <span style="font-weight: bold; color: #00FF00;"><%= hours %>س <%= mins %>د</span>
                        </li>
                    <% }) %>
                <% } else { %>
                    <li style="padding: 10px; text-align: center; color: rgba(255,255,255,0.5);">لا توجد إحصائيات بعد</li>
                <% } %>
            </ul>
        </div>

        <!-- Reactions Leaderboard -->
        <div class="glass-panel">
            <h3 style="color: var(--primary); margin-bottom: 15px;"><i class="fa-solid fa-face-smile"></i> أكثر الأعضاء استخداماً للريأكشن</h3>
            <ul style="list-style: none; padding: 0;">
                <% if (topReactions && topReactions.length > 0) { %>
                    <% topReactions.forEach((user, index) => { %>
                        <li style="display: flex; align-items: center; justify-content: space-between; padding: 10px; background: rgba(255,255,255,0.05); margin-bottom: 8px; border-radius: 8px;">
                            <div style="display: flex; align-items: center; gap: 10px;">
                                <span style="font-weight: bold; color: var(--primary);"><%= index + 1 %>.</span>
                                <span><i class="fa-solid fa-user"></i> ID: <%= user.userId %></span>
                            </div>
                            <span style="font-weight: bold; color: #FFFF00;"><%= user.reactionsCount || 0 %> تفاعل</span>
                        </li>
                    <% }) %>
                <% } else { %>
                    <li style="padding: 10px; text-align: center; color: rgba(255,255,255,0.5);">لا توجد إحصائيات بعد</li>
                <% } %>
            </ul>
        </div>

    </div>
</main>

<%- include('partials/footer') %>
